# Настройки SMTP-сервера Yandex
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Для отключения отправки писем (в тестовой среде)
MAIL_SUPPRESS_SEND=True

# Настройки базы данных и другие параметры
SECRET_KEY=your_secret_key
DATABASE_URI=sqlite:///fitness_gym.db